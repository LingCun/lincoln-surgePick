---
import Base from '../layouts/Base.astro';
import TickerSearch from '../components/TickerSearch.astro';
import SimController from '../components/SimController.astro';
export const prerender = false;
---
<Base title="surgePick — 종목 시뮬레이션">
  <section class="space-y-4">
    <h1 class="text-xl font-bold">종목 시뮬레이션</h1>
    <p class="text-sm text-slate-400">
      종목 하나 선택 + 예측 기간 → 과거 1달 실제 + 과거 유사 regime 평균 기반 예측선.
    </p>

    <TickerSearch />

    <div id="horizon-picker" class="bg-slate-900/60 rounded-lg p-3 space-y-2">
      <div class="text-xs text-slate-400">조회 조건 · 예측 기간</div>
      <div class="flex gap-2">
        <button data-hz="30" class="px-4 py-2 rounded text-sm font-semibold transition bg-cyan-600 text-white shadow">1달 예측</button>
        <button data-hz="60" class="px-4 py-2 rounded text-sm font-semibold transition bg-slate-800 text-slate-400 hover:bg-slate-700">2달 예측</button>
        <button data-hz="90" class="px-4 py-2 rounded text-sm font-semibold transition bg-slate-800 text-slate-400 hover:bg-slate-700">3달 예측</button>
      </div>
    </div>

    <div id="sim-result" class="hidden space-y-6"></div>
    <SimController />
  </section>
</Base>
