---
import Base from '../layouts/Base.astro';
import TickerSearch from '../components/TickerSearch.astro';
import SimController from '../components/SimController.astro';
import MethodNote from '../components/MethodNote.astro';
import regimeData from '../data/regime.json';
export const prerender = false;
const { asOf: regimeAsOf, asOfKR, asOfUS } = regimeData as any;
---
<Base title="lincoln-surgePick — 시뮬레이션" asOf={regimeAsOf} asOfKR={asOfKR} asOfUS={asOfUS}>
  <section class="space-y-6">
    <div class="space-y-2">
      <h1 class="text-2xl md:text-3xl font-bold tracking-tight">
        <span class="bg-gradient-to-r from-cyan-300 to-sky-500 bg-clip-text text-transparent">종목 시뮬레이션</span>
      </h1>
      <p class="text-sm text-slate-400 leading-relaxed">
        종목과 기간을 고르면, 과거 한 달의 실제 흐름과 함께 유사 시장 국면의 평균 궤적을 평균해 1·2·3개월 예측선을 그립니다.
      </p>
    </div>

    <TickerSearch />

    <div id="horizon-picker" class="bg-slate-900/40 border border-slate-800 rounded-xl p-4 space-y-3">
      <div class="text-xs uppercase tracking-wide text-slate-500 font-semibold">예측 기간</div>
      <div class="grid grid-cols-3 gap-2">
        <button data-hz="30" class="hz-btn hz-active">
          <span class="text-lg font-bold">1M</span>
          <span class="text-[10px] opacity-75">1달</span>
        </button>
        <button data-hz="60" class="hz-btn">
          <span class="text-lg font-bold">2M</span>
          <span class="text-[10px] opacity-75">2달</span>
        </button>
        <button data-hz="90" class="hz-btn">
          <span class="text-lg font-bold">3M</span>
          <span class="text-[10px] opacity-75">3달</span>
        </button>
      </div>
    </div>

    <div id="sim-result" class="hidden space-y-6"></div>
    <SimController />

    <MethodNote summary="예측선은 어떻게 그려지나요?">
      <div class="space-y-1">
        <h3 class="text-sm font-semibold text-cyan-300">1. 유사 사례 추출</h3>
        <p>
          현재 국면과 똑같은 (시장 + 라벨 + 변동성 밴드) 조합이 과거 5년 안에 있던 날짜들을 모두 뽑아옵니다.
          예: 오늘이 <em class="text-emerald-300 not-italic">KR · bull · 변동성 높음</em>이면, 2021~2025년 중 같은 조건이었던 모든 날짜.
          표본이 부족하면 변동성 밴드 → 라벨 순으로 조건을 풀어 더 많은 사례를 매칭합니다(폴백).
        </p>
      </div>
      <div class="space-y-1">
        <h3 class="text-sm font-semibold text-cyan-300">2. 궤적 평균</h3>
        <p>
          매칭된 각 과거 날짜의 종가를 0%로 잡고, 선택한 종목의 +1일, +2일, …, +N일 수익률 곡선을 그려요.
          이 곡선들의 <span class="font-semibold text-amber-300">메디안(p50)</span>이 예측선,
          <span class="font-semibold text-amber-200">p25~p75 구간</span>이 신뢰 밴드입니다.
        </p>
      </div>
      <div class="space-y-1">
        <h3 class="text-sm font-semibold text-cyan-300">한계 — 꼭 알아두세요</h3>
        <ul class="list-disc list-inside space-y-1.5 marker:text-slate-500">
          <li>과거 패턴이 미래에도 반복된다는 보장은 없습니다. <strong>상관 ≠ 인과.</strong></li>
          <li>매칭 차원은 시장 regime + VIX 밴드뿐. <strong>섹터·시총·실적·뉴스는 반영하지 않습니다.</strong></li>
          <li>표본이 30건 미만이면 메디안이 한쪽으로 치우치기 쉽습니다. 신뢰도 워닝을 확인하세요.</li>
          <li>소형주는 자체 변동성이 커서 밴드가 매우 넓어집니다. 예측선만 보고 판단하지 마세요.</li>
          <li>모든 가격은 EOD(종가) 기준. 실시간 가격이 아닙니다.</li>
        </ul>
      </div>
    </MethodNote>
  </section>
</Base>

<style is:global>
  .hz-btn {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 2px;
    padding: 12px 8px;
    border-radius: 10px;
    background: rgb(30 41 59);
    color: rgb(148 163 184);
    font-weight: 600;
    transition: all 160ms ease;
    border: 1px solid transparent;
  }
  .hz-btn:hover {
    background: rgb(51 65 85);
    color: rgb(226 232 240);
  }
  .hz-btn.hz-active {
    background: linear-gradient(135deg, rgb(8 145 178), rgb(14 116 144));
    color: white;
    border-color: rgb(34 211 238);
    box-shadow: 0 4px 14px -2px rgba(34, 211, 238, 0.35);
  }
</style>
