---
import Base from '../layouts/Base.astro';
import StatsTable from '../components/StatsTable.astro';
import backtest from '../data/backtest.json';

const { window: winRange, simDays, totals, byMarket, byHorizon, byMarketHorizon, byYear, picks } = backtest;

const fmtPct = (v: number | null, digits = 1) =>
  v == null ? 'N/A' : `${(v * 100).toFixed(digits)}%`;
const fmtReturn = (v: number | null) =>
  v == null ? 'N/A' : `${v >= 0 ? '+' : ''}${(v * 100).toFixed(2)}%`;
const returnColor = (v: number | null) =>
  v == null ? 'text-slate-400' : v > 0 ? 'text-emerald-600' : v < 0 ? 'text-rose-600' : 'text-slate-600';

const yearRows = Object.entries(byYear)
  .sort(([a], [b]) => a.localeCompare(b))
  .map(([year, b]: any) => ({ label: year, ...b }));

const horizonRows = ['단기', '중기', '장기'].map((h) => ({ label: h, ...byHorizon[h] }));
const marketRows = ['KR', 'US'].map((m) => ({ label: m, ...byMarket[m] }));
const marketHorizonRows = Object.entries(byMarketHorizon).map(([k, b]: any) => ({ label: k, ...b }));

const picksMatured = picks.filter((p: any) => p.status === 'matured');
---

<Base title="surgePick — 백테스트">
  <div class="space-y-4">
    <header class="flex items-baseline justify-between">
      <h1 class="text-xl font-bold text-slate-100">📊 백테스트 결과</h1>
      <a href="/" class="text-xs text-slate-400 hover:text-slate-200">← 홈</a>
    </header>

    <p class="text-xs text-slate-400">
      기간: <span class="font-medium text-slate-200">{winRange.start} → {winRange.end}</span>
      · 시뮬레이션 거래일 <span class="font-medium text-slate-200">{simDays}</span>일
    </p>

    <section class="rounded-2xl bg-white p-4 shadow-sm ring-1 ring-slate-200">
      <h2 class="mb-2 text-sm font-semibold text-slate-700">전체 요약</h2>
      <div class="grid grid-cols-4 gap-2 text-center">
        <div>
          <div class="text-[10px] text-slate-500">건수</div>
          <div class="text-lg font-bold text-slate-900 tabular-nums">{totals.count}</div>
        </div>
        <div>
          <div class="text-[10px] text-slate-500">진입률</div>
          <div class="text-lg font-bold text-slate-900 tabular-nums">{fmtPct(totals.pickRate, 1)}</div>
        </div>
        <div>
          <div class="text-[10px] text-slate-500">승률</div>
          <div class="text-lg font-bold text-slate-900 tabular-nums">{fmtPct(totals.winRate, 1)}</div>
        </div>
        <div>
          <div class="text-[10px] text-slate-500">평균 수익</div>
          <div class={`text-lg font-bold tabular-nums ${returnColor(totals.meanReturn)}`}>
            {fmtReturn(totals.meanReturn)}
          </div>
        </div>
      </div>
      {totals.active > 0 && (
        <p class="mt-2 text-[10px] text-slate-400">
          보유 중(만기 미도달) {totals.active}건은 집계 제외.
        </p>
      )}
    </section>

    <StatsTable title="연도별" rows={yearRows} highlightLabel="2022" />
    <StatsTable title="보유기간별" rows={horizonRows} />
    <StatsTable title="시장별" rows={marketRows} />
    <StatsTable title="시장 × 보유기간" rows={marketHorizonRows} />

    <section class="rounded-2xl bg-white p-4 shadow-sm ring-1 ring-slate-200">
      <h2 class="mb-3 text-sm font-semibold text-slate-700">전체 픽 ({picksMatured.length})</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-xs">
          <thead>
            <tr class="border-b border-slate-200 text-left text-slate-500">
              <th class="py-2 pr-2 font-medium">매수일</th>
              <th class="py-2 pr-2 font-medium">종목</th>
              <th class="py-2 pr-2 text-right font-medium">기간</th>
              <th class="py-2 text-right font-medium">수익률</th>
            </tr>
          </thead>
          <tbody>
            {picksMatured.map((p: any) => (
              <tr class="border-b border-slate-100 last:border-0">
                <td class="py-2 pr-2 tabular-nums text-slate-600">{p.buyDate}</td>
                <td class="py-2 pr-2">
                  <span class="font-medium text-slate-800">{p.ticker}</span>
                  <span class="ml-1 text-[10px] text-slate-400">{p.market}·{p.horizon}</span>
                </td>
                <td class="py-2 pr-2 text-right tabular-nums text-slate-500">{p.holdDays}d</td>
                <td class={`py-2 text-right tabular-nums font-medium ${returnColor(p.return)}`}>
                  {fmtReturn(p.return)}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <p class="text-[10px] leading-relaxed text-slate-400">
      ⓘ 한계: 종목 풀이 2026년 기준으로 고정되어 있어 생존편향(survivorship bias)이 존재합니다.
      과거 시점에 상장폐지된 종목은 포함되지 않으며, 결과는 알고리즘 자체의 동작 검증 목적입니다.
    </p>
  </div>
</Base>
