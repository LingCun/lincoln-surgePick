---
import '../styles/global.css';
import Logo from '../components/Logo.astro';

interface Props {
  title?: string;
  description?: string;
  asOf?: string;
  asOfKR?: string;
  asOfUS?: string;
}
const { title = 'lincoln-surgePick', description = '시장 국면 매칭 기반 종목 예측 시뮬레이터', asOf, asOfKR, asOfUS } = Astro.props;
const ogImage = new URL('/og-default.png', Astro.site);
const canonical = new URL(Astro.url.pathname, Astro.site);
function fmt(iso?: string) {
  if (!iso) return null;
  const d = new Date(iso);
  const opts = { month: '2-digit', day: '2-digit', hour: '2-digit', minute: '2-digit', timeZone: 'Asia/Seoul', hour12: false } as const;
  return d.toLocaleString('ko-KR', opts);
}
const krText = fmt(asOfKR);
const usText = fmt(asOfUS);
const fallbackText = !krText && !usText ? fmt(asOf) : null;

const path = Astro.url.pathname;
const activeHome = path === '/' || path === '';
const activeSim = path.startsWith('/sim');
const activeSchedule = path.startsWith('/schedule');
const activeAbout = path.startsWith('/about');
const navBase = 'pb-3 px-1 border-b-2 transition text-base';
const navIdle = 'border-transparent text-slate-400 hover:text-slate-200 hover:border-slate-500';
const navActive = 'border-cyan-400 text-cyan-300 font-semibold';
---
<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#020617" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="lincoln-surgePick" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js" is:inline></script>
    <script src="https://cdn.jsdelivr.net/npm/chartjs-adapter-date-fns@3.0.0/dist/chartjs-adapter-date-fns.bundle.min.js" is:inline></script>
  </head>
  <body class="bg-slate-950 text-slate-100 min-h-screen font-sans antialiased">
    <header class="px-4 pt-6 pb-2 max-w-screen-md mx-auto">
      <div class="flex items-start justify-between gap-3">
        <a href="/" aria-label="lincoln-surgePick 홈" class="shrink-0"><Logo size={30} /></a>
        {(krText || usText) && (
          <div class="text-[11px] text-slate-400 text-right leading-snug space-y-0.5">
            {krText && <div class="flex items-center justify-end gap-1.5"><span class="px-1.5 py-px rounded bg-sky-500/15 text-sky-300 font-bold text-[10px]">KR</span><span class="tabular-nums">{krText}</span></div>}
            {usText && <div class="flex items-center justify-end gap-1.5"><span class="px-1.5 py-px rounded bg-amber-500/15 text-amber-300 font-bold text-[10px]">US</span><span class="tabular-nums">{usText}</span></div>}
          </div>
        )}
        {!krText && !usText && fallbackText && (
          <span class="text-xs text-slate-400">{fallbackText} 기준</span>
        )}
      </div>
      <nav class="mt-4 flex gap-6 border-b border-slate-800">
        <a href="/" class={`${navBase} ${activeHome ? navActive : navIdle}`} data-nav="home">시장</a>
        <a href="/schedule" class={`${navBase} ${activeSchedule ? navActive : navIdle}`} data-nav="schedule">일정</a>
        <a href="/sim" class={`${navBase} ${activeSim ? navActive : navIdle}`} data-nav="sim">시뮬레이션</a>
        <a href="/about" class={`${navBase} ${activeAbout ? navActive : navIdle} ml-auto`} data-nav="about">방법</a>
      </nav>
    </header>
    <main class="px-4 pb-12 max-w-screen-md mx-auto">
      <slot />
    </main>
    <footer class="px-4 py-8 max-w-screen-md mx-auto text-xs text-slate-500 text-center space-y-1">
      <p>본 사이트의 정보는 투자 판단의 참고용이며 매수/매도 추천이 아닙니다.</p>
      <p>모든 투자의 책임은 본인에게 있습니다. Source: Yahoo Finance</p>
    </footer>
  </body>
</html>
