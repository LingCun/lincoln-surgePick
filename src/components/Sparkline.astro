---
interface Props {
  values: number[];
  width?: number;
  height?: number;
  color?: string;
}
const { values, width = 300, height = 60, color = '#60a5fa' } = Astro.props;

const min = Math.min(...values);
const max = Math.max(...values);
const range = max - min || 1;
const stepX = width / Math.max(values.length - 1, 1);
const points = values
  .map((v, i) => {
    const x = i * stepX;
    const y = height - ((v - min) / range) * height;
    return `${x.toFixed(1)},${y.toFixed(1)}`;
  })
  .join(' ');
const last = values[values.length - 1];
const lastX = (values.length - 1) * stepX;
const lastY = height - ((last - min) / range) * height;
const gradId = `g${Math.random().toString(36).slice(2, 8)}`;
const areaPath = `M0,${height} L${points.replace(/ /g, ' L')} L${width},${height} Z`;
---
<svg viewBox={`0 0 ${width} ${height}`} preserveAspectRatio="none" class="w-full" style={`height:${height}px`} aria-hidden="true">
  <defs>
    <linearGradient id={gradId} x1="0" x2="0" y1="0" y2="1">
      <stop offset="0%" stop-color={color} stop-opacity="0.4" />
      <stop offset="100%" stop-color={color} stop-opacity="0" />
    </linearGradient>
  </defs>
  <path d={areaPath} fill={`url(#${gradId})`} />
  <polyline points={points} fill="none" stroke={color} stroke-width="1.5" stroke-linejoin="round" />
  <circle cx={lastX} cy={lastY} r="3" fill={color} />
</svg>
