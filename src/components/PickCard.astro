---
import Sparkline from './Sparkline.astro';

interface Props {
  ticker: string;
  name: string;
  score: number;
  closes30: number[];
  reason: string;
  horizon?: '단기' | '중기' | '장기';
  holdDays?: number;
}
const { ticker, name, score, closes30, reason, horizon, holdDays } = Astro.props;

const horizonColor =
  horizon === '단기' ? 'bg-horizon-short/20 text-horizon-short'
  : horizon === '중기' ? 'bg-horizon-mid/20 text-horizon-mid'
  : horizon === '장기' ? 'bg-horizon-long/20 text-horizon-long'
  : 'bg-slate-700 text-slate-300';
---
<article class="rounded-2xl bg-slate-900 border border-slate-800 p-4 space-y-3">
  <header class="flex items-baseline justify-between">
    <div>
      <h3 class="text-base font-semibold">{name}</h3>
      <p class="text-xs text-slate-400">{ticker}</p>
    </div>
    <div class="flex items-center gap-2">
      {horizon && (
        <span class={`text-xs font-semibold px-2 py-0.5 rounded-full ${horizonColor}`}>{horizon}{holdDays ? ` · ${holdDays}일` : ''}</span>
      )}
      <span class="text-sm font-medium text-brand-pick">score {score}</span>
    </div>
  </header>
  <Sparkline values={closes30} color="#60a5fa" />
  <p class="text-sm leading-relaxed text-slate-200">{reason}</p>
</article>
