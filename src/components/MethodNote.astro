---
// 페이지 하단에 접이식으로 붙는 "이 화면은 어떻게 작동하나요?" 설명 블록.
// 기존 /about(방법론) 페이지의 내용을 각 페이지 맥락에 맞춰 분산하기 위한 공용 컴포넌트.
interface Props {
  summary: string;
}
const { summary } = Astro.props;
---
<details class="group bg-slate-900/40 border border-slate-800 rounded-xl overflow-hidden">
  <summary class="cursor-pointer select-none px-5 py-3.5 flex items-center gap-2 text-sm font-medium text-slate-300 hover:text-slate-100 transition list-none [&::-webkit-details-marker]:hidden">
    <span class="text-cyan-400 transition-transform duration-200 group-open:rotate-90" aria-hidden="true">▸</span>
    {summary}
  </summary>
  <div class="px-5 pb-5 pt-3 text-sm text-slate-300 leading-relaxed space-y-3 border-t border-slate-800/60">
    <slot />
  </div>
</details>
