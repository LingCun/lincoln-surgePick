---
import ThemeCard from './ThemeCard.astro';

interface Props {
  items: Array<{
    id: string;
    name: string;
    icon: string;
    label: string;
    weight: string;
    comment: string;
    closes60: number[];
  }>;
  variant: 'popular' | 'value';
  ariaLabel: string;
}
const { items, variant, ariaLabel } = Astro.props;
---
<div
  class="flex gap-2 overflow-x-auto no-scrollbar snap-x snap-mandatory pb-2 -mx-4 px-4 scroll-smooth"
  role="region"
  aria-label={ariaLabel}
>
  {items.length === 0 ? (
    <p class="text-sm text-slate-400 py-3">데이터 부족.</p>
  ) : (
    items.map((t) => <ThemeCard {...t} variant={variant} />)
  )}
</div>
