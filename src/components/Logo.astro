---
interface Props {
  size?: number;          // 심볼 높이(px)
  withWordmark?: boolean; // 워드마크 표시 여부
  class?: string;
}
const { size = 28, withWordmark = true, class: className = '' } = Astro.props;
const wordSize = Math.round(size * 0.82);
---
<span class={`inline-flex items-center gap-2 ${className}`}>
  <svg width={size} height={size} viewBox="0 0 64 64" fill="none" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
    <defs>
      <linearGradient id="logoGrad" x1="6" y1="44" x2="48" y2="12" gradientUnits="userSpaceOnUse">
        <stop stop-color="#22d3ee" />
        <stop offset="1" stop-color="#0ea5e9" />
      </linearGradient>
    </defs>
    <path d="M6 44 L26 44 L44 14" stroke="url(#logoGrad)" stroke-width="4.5" stroke-linecap="round" stroke-linejoin="round" />
    <path d="M34 13 L45 13 L45 24" stroke="#67e8f9" stroke-width="4.5" stroke-linecap="round" stroke-linejoin="round" />
  </svg>
  {withWordmark && (
    <span class="font-bold tracking-tight text-slate-200" style={`font-size:${wordSize}px`}>
      lincoln-<span class="bg-gradient-to-r from-cyan-300 to-sky-500 bg-clip-text text-transparent">surgePick</span>
    </span>
  )}
</span>
