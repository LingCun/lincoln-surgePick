---
interface Props {
  groupId: string;
}
const { groupId } = Astro.props;
---
<div class="theme-tabs flex gap-1 mb-3" data-group={groupId} role="tablist">
  <button
    type="button"
    class="theme-tab flex-1 py-2 rounded-lg text-sm font-medium bg-orange-500 text-white"
    data-tab="popular"
    role="tab"
    aria-selected="true"
  >🔥 인기</button>
  <button
    type="button"
    class="theme-tab flex-1 py-2 rounded-lg text-sm font-medium bg-slate-800 text-slate-300"
    data-tab="value"
    role="tab"
    aria-selected="false"
  >💎 투자가치</button>
</div>
